{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "soe_dashboard",
  "version": "0.1.2",
  "identifier": "com.soe.supportdesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SoE Supporter Dashboard",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQzMjhERDlERjA4ODE1RjIKUldUeUZZanduZDBvUXphU1kwTWErc3J5VE10N2N6MzdzK1l4dXcrbTJxZkF3OStGdWRYZVlCcXoK",
      "endpoints": [
        "https://github.com/Silkester0815/soe_dashboard/releases/latest/download/latest.json"
      ]
    }
  }
}
